# Copy to .env and fill in. Required: APP_FERNET_KEY (generate with the command below).
#
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
#

POSTGRES_USER=bookmark
POSTGRES_PASSWORD=bookmark
POSTGRES_DB=bookmark

APP_FERNET_KEY=

# How often the scheduler runs each account (minutes).
SYNC_INTERVAL_MIN=15

# Allowed origin for the browser UI.
CORS_ORIGINS=http://localhost:3000

# X (Twitter) Bookmarks GraphQL queryId. Rotates every few months.
# Leave empty to use the known-good default in config.py; override here when X breaks.
X_BOOKMARKS_QUERY_ID=

# Browser-visible API base.
NEXT_PUBLIC_API_BASE=http://localhost:8000
