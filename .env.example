# Copy to .env and fill in. Required: APP_FERNET_KEY (generate with the command below).
#
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
#

POSTGRES_USER=bookmark
POSTGRES_PASSWORD=bookmark
POSTGRES_DB=bookmark

APP_FERNET_KEY=

# How often the scheduler runs each account (minutes).
SYNC_INTERVAL_MIN=15

# Allowed origin for the browser UI.
CORS_ORIGINS=http://localhost:3000

# X (Twitter) Bookmarks GraphQL queryId. Rotates every few months.
# Leave empty to use the known-good default in config.py; override here when X breaks.
X_BOOKMARKS_QUERY_ID=

# Browser-visible API base.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# On-disk markdown vault (the single source of truth).
#
# Resolution order (first non-empty wins):
#   1. VAULT_DIR env var                      — explicit override
#   2. ~/.config/bookmark-me/config.json      — set via the Settings UI
#   3. ~/.config/bookmark-me/vault_dir/       — default
#
# Leave VAULT_DIR unset for local dev (UI wins). Setting it forces the path
# and disables the "Move vault" button in the UI until it's cleared again.
#
# Docker users: compose.yaml pins VAULT_DIR to /app/vault inside the
# container. Override the host-side mount path with HOST_VAULT_DIR (defaults
# to ~/.config/bookmark-me/vault_dir on the host).
# VAULT_DIR=
# HOST_VAULT_DIR=
